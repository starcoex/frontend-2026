{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["dom"],
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "vite/client"
    ],
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@starcoex-frontend/graphql": ["../../libs/graphql/src/index.ts"]
    }
  },
  "exclude": [
    "out-tsc",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "src/**/*.spec.jsx",
    "src/**/*.test.jsx",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../../libs/features/payments/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/notifications/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/address/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/media/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/orders/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/loyalty/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/contact/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/jobs/tsconfig.lib.json"
    },
    {
      "path": "../../libs/pwa/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/auth/tsconfig.lib.json"
    },
    {
      "path": "../../libs/graphql/tsconfig.lib.json"
    },
    {
      "path": "../../libs/features/common/tsconfig.lib.json"
    }
  ]
}
